# Netlify 서버 레벨 캐시 제어 설정

# HTML 파일 — 항상 최신 버전 제공 (캐시 금지)
/dashboard.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/register.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/find-id.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/find-pw.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# CSS / JS — 버전 쿼리스트링(?v=...) 사용 시 장기 캐시 허용
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# 아이콘 / 이미지 — 장기 캐시
/icons/*
  Cache-Control: public, max-age=31536000, immutable

# Service Worker — 항상 최신 버전
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# manifest — 짧은 캐시
/manifest.json
  Cache-Control: public, max-age=3600
